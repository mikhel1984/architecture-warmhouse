@startuml WarmHouse_containers

title WarmHouse updated system containers

top to bottom direction

'!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml
!include <C4/C4_Component.puml>

Person(user, "User", "A user of a WarmHouse system")
System(WarmHouseSystem, "WarmHouse system", "System managing smart devices")

Container_Boundary(WarmHouseSystem, "WarmHouse system") {
    Container(WebApp, "Web application", "Java", "Handles user interactions")
    ContainerDb(Database, "PostgreSQL", "Stores user data and device configuration")
    Container(TemperatureService, "Heating service", "Go", "Interact with heating devices")
    Container(CameraService, "Camera service", "Go", "Interact with camera")
    Container(DoorService, "Door service", "Go", "Interact with doors")
    Container(LightService, "Light service", "Go", "Interact with lights")
    Container(Getway, "Getway API")
}

System_Ext(TemperatureDev, "Heating system", "Control heating, read temperature")
System_Ext(Camera, "Camera", "Translate video")
System_Ext(Doors, "Door system", "Open/close the door")
System_Ext(LightDev, "Light system", "Turn on/off the light")

Rel(user, WebApp, "Uses the system")
Rel_L(WebApp, Database, "Reads/writes data")
Rel(WebApp, Getway, "Communicate sensors")
Rel(Getway, TemperatureService, "Communicate with heating")
Rel(Getway, CameraService, "Communicate with camera")
Rel(Getway, DoorService, "Comminucate with doors")
Rel(Getway, LightService, "Communicate with lights")

Rel(TemperatureService, TemperatureDev, "Interact API")
Rel(LightService, LightDev, "Interact API")
Rel(CameraService, Camera, "Interact API")
Rel(DoorService, Doors, "Interact API")

@enduml